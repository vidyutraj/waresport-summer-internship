# Copy to .env and fill in real values (never commit .env)

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/waresport?schema=public"

# First calendar day of program Week 1 (YYYY-MM-DD)
INTERNSHIP_PROGRAM_START_DATE=2026-05-04

# Local: http://localhost:3000 — On Vercel use your live URL, e.g. https://your-app.vercel.app (not localhost)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-long-random-string-for-production"

# SMTP (optional — for password reset emails)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# ── Seed (npm run db:seed) — passwords are NOT in git; set locally / in CI secrets
# Full wipe + reseed: npm run db:seed:fresh  (deletes all users, tasks, logs, resources, announcements)
SEED_ADMIN_1_NAME="Primary Admin"
SEED_ADMIN_1_EMAIL="admin1@example.com"
SEED_ADMIN_1_PASSWORD="generate-a-strong-password"
SEED_ADMIN_2_NAME="Secondary Admin"
SEED_ADMIN_2_EMAIL="admin2@example.com"
SEED_ADMIN_2_PASSWORD="generate-a-strong-password"
